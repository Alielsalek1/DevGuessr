# Project Configuration
PROJECT_NAME="DevGuessr"
PROJECT_DESCRIPTION="The Architect's Forge - A high-performance, resilient backend template with Clean Architecture"
FRONTEND_API_BASE_URL=/api/v1

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Development

# API Configuration
API_PORT=5000

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=devguessr_db
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# Database Connection String
CONNECTION_STRING=Host=postgres;Port=5432;Database=devguessr_db;Username=postgres;Password=postgres;

# Email configuration
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=no-reply@devguessr.com
EMAIL_ENABLE_SSL=true

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CONNECTION_STRING=redis:6379

# Seq Configuration
SEQ_URL=http://seq

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# JWT Configuration
JWT_KEY=super-secret-key-change-me-in-production-1234567890
JWT_ISSUER=devguessr
JWT_AUDIENCE=devguessr_users
JWT_DURATION_IN_MINUTES=90

Google__ClientId=
Google__ClientSecret=

# Upload Configuration
UPLOAD_PATH=uploads
UPLOAD_BASE_URL=/uploads